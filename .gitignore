# ============================================================
#  .gitignore — NEVER commit secrets or large data files
# ============================================================

# Secrets — CRITICAL
.env
*.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Results & logs (can be large)
results/
logs/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
*.swp

# Docker
*.tar
trading-deploy_accessKeys.csv

# Databento local data cache (keep folder structure, not data files)
.cache/databento/*.json

# Computed results cache (auto-generated, recomputed on demand)
.cache/computed/
.cache/prices/
.cache/factors/
# NB: .cache/databento/ is intentionally NOT ignored — user wants it committed
