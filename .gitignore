# ============================================================
#  .gitignore — NEVER commit secrets or large data files
# ============================================================

# Secrets — CRITICAL
.env
*.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Results & logs (can be large)
results/
logs/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
*.swp

# Docker
*.tar
trading-deploy_accessKeys.csv

# Databento local data cache (keep folder structure, not data files)
.cache/databento/*.json

# Computed results cache (auto-generated, recomputed on demand)
.cache/computed/
.cache/prices/
.cache/factors/

# Alpaca fetched data (700MB+, not for git)
data_cache/

# Diagnostic / debug scripts (one-off, not production)
diagnose_fetch.py
fetch_all_verbose.py
validate_cache.py
daily_update_status_*.md

# Duplicate directories with spaces (accidental copies)
*" b"/
momentum_signals_exploration\ b/
volatility_prediction\ b/
