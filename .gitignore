# ============================================================
#  .gitignore — NEVER commit secrets or large data files
# ============================================================

# Secrets — CRITICAL
.env
*.pem
*.key
secrets/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Results & logs (can be large)
results/
logs/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
*.swp

# Docker
*.tar
trading-deploy_accessKeys.csv
