# Databento API
DATABENTO_API_KEY=your_databento_api_key_here

# Alpaca API
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Storage
STORAGE_PROVIDER=local
RAW_LAKE_PATH=/data/raw
ANALYTICS_LAKE_PATH=/data/analytics
FEATURE_STORE_PATH=/data/features

# Azure (if using Azure Blob Storage)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=market-data

# AWS (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=market-data

# GCS (if using Google Cloud Storage)
GCS_PROJECT=
GCS_BUCKET=market-data

# Monitoring
PROMETHEUS_PORT=9090
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# Environment
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Prefect
PREFECT_API_URL=http://localhost:4200/api
