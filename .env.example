# ============================================================
#  .env.example — copy to .env and fill in your values
#  NEVER commit .env to git.
# ============================================================

# ── System ───────────────────────────────────────────────────
TRADING_MODE=paper                    # paper | live
TZ=Europe/Athens
HEALTHCHECK_PORT=8080

# ── Alpaca Paper Trading (recommended for paper mode) ────────
# Sign up free at https://alpaca.markets → Paper Trading
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Also accepted (for backwards-compat with alpaca-py SDK):
# APCA_API_KEY_ID=your_alpaca_key_here
# APCA_API_SECRET_KEY=your_alpaca_secret_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# ── Databento (optional — premium market data) ────────────────
# Sign up at https://app.databento.com
DATABENTO_API_KEY=your_databento_key_here

# ── Alerts ─────────────────────────────────────────────────────
ALERT_EMAIL=your_email@example.com
# Email delivery uses Gmail drafts via Perplexity Computer cron —
# no SMTP credentials needed in GitHub Actions.

# ── Binance Testnet (for crypto paper trading) ───────────────
# Get testnet keys at https://testnet.binance.vision
BINANCE_API_KEY=your_binance_testnet_key
BINANCE_API_SECRET=your_binance_testnet_secret
BINANCE_TESTNET=true

# ── IBKR (Interactive Brokers) ───────────────────────────────
# Only needed if using IBKR — run IB Gateway on same host
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497          # 7497 = paper TWS / 4002 = paper IB Gateway
# IBKR_CLIENT_ID=1
# IBKR_ACCOUNT=DU123456   # your paper account ID

# ── AWS (for reporting features) ─────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Daily email report (AWS SES — both addresses must be SES-verified)
SES_SENDER=reports@yourdomain.com
SES_RECIPIENT=you@yourdomain.com

# S3 bucket for storing HTML reports (must exist, create via console/CLI)
S3_BUCKET=your-trading-reports-bucket

# Kalshi (optional — public endpoints work without auth)
# KALSHI_API_KEY=your_key_id
# KALSHI_PRIVATE_KEY_PATH=path/to/private_key.pem
